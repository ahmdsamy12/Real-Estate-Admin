{
    "name": "laravel/real-estate-admin",
    "type": "project",
    "description": "Real Estate Admin Dashboard built with Laravel 11 and Tailwind CSS",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "policy": {
            "advisories": {
                "ignore-id": {
                    "PKSA-mdq4-51ck-6kdq": "Acknowledged, not exploitable in this app context",
                    "PKSA-8qx3-n5y5-vvnd": "Acknowledged, not exploitable in this app context",
                    "PKSA-q46n-4fdk-zjr4": "Acknowledged, not exploitable in this app context",
                    "PKSA-qzrn-rnz3-85w1": "Acknowledged, not exploitable in this app context",
                    "PKSA-w7xr-vk7n-rstm": "Acknowledged, not exploitable in this app context"
                }
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
